# Sourced by bash on Linux (CustomPiOS build / CI); CRLF breaks `source` with $'\r' errors
src/config text eol=lf
Makefile text eol=lf
scripts/*.sh text eol=lf

# CustomPiOS module scripts must use LF inside the Linux chroot
src/modules/**/start_chroot_script text eol=lf
src/modules/**/config text eol=lf
# RatOS hotspot payload (bash scripts + configs) must stay LF for the image chroot
src/modules/hotspot/filesystem/** text eol=lf
# Mainsail module payloads (shell shebangs break in chroot if CRLF → "required file not found")
src/modules/mainsail/filesystem/** text eol=lf
# Configurator overlay (sudoers/visudo rejects CRLF; shell hooks need LF)
src/modules/ratos-configurator/filesystem/** text eol=lf
