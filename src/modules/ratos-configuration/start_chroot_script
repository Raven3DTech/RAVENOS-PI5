#!/usr/bin/env bash
# Ship RatOS-configuration tree for RatOS Configurator + board templates.
# Does NOT run scripts/ratos-install.sh here (requires `pi` user + running `ratos` CLI).
set -ex

source /common.sh
install_cleanup_trap

apt-get update --allow-releaseinfo-change
# ratos-install.sh declares: python3-numpy python3-matplotlib curl (numpy often from Klipper module)
apt-get install -y --no-install-recommends python3-matplotlib curl

CONFIG_PARENT="$(dirname "${RATOS_CONFIGURATION_PATH}")"
mkdir -p "${CONFIG_PARENT}"
pushd "${CONFIG_PARENT}" &>/dev/null

if [[ -d "${RATOS_CONFIGURATION_PATH}/.git" ]]; then
    echo_green "RatOS-configuration already present, skipping clone"
else
    rm -rf "${RATOS_CONFIGURATION_PATH}"
    echo_green "Cloning RatOS-configuration (${RATOS_CONFIGURATION_BRANCH}) ..."
    sudo -u "${BASE_USER}" git clone -b "${RATOS_CONFIGURATION_BRANCH}" --depth 1 \
        "${RATOS_CONFIGURATION_REPO}" "$(basename "${RATOS_CONFIGURATION_PATH}")"
fi

chown -R "${BASE_USER}:${BASE_USER}" "${RATOS_CONFIGURATION_PATH}"
popd &>/dev/null

echo_green "RatOS-configuration installed at ${RATOS_CONFIGURATION_PATH}"
