#!/bin/bash
# ============================================================
# R3DTOS PI5 — ensure-user-shell
# Raspberry Pi OS images may ship the default user with /usr/sbin/nologin.
# SSH then accepts the password but prints "This account is currently not available."
# Fix the passwd entry inside the chroot so out-of-box SSH matches RatOS expectations.
# ============================================================
set -ex

source /common.sh
install_cleanup_trap

U="${BASE_USER:-pi}"
if id -u "${U}" >/dev/null 2>&1; then
  echo_green "Setting login shell for ${U} → /bin/bash"
  usermod -s /bin/bash "${U}"
  getent passwd "${U}" || true
else
  echo_green "User ${U} not present in chroot yet; skipping shell fix"
fi
