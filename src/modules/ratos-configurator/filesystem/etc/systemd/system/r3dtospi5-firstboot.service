[Unit]
Description=R3DTOS PI5 First Boot Setup
After=network.target
ConditionPathExists=/home/pi/scripts/r3dtospi5-firstboot.sh

[Service]
Type=oneshot
ExecStart=/bin/bash /home/pi/scripts/r3dtospi5-firstboot.sh
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal
SyslogIdentifier=r3dtospi5-firstboot

[Install]
WantedBy=multi-user.target
